{
  "request": {
    "method": "GET",
    "urlPathPattern": "/([a-zA-Z0-9]+)/(.+)"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "{{request.path.[0]}}-{{request.path.[1]}}",
      "kod": "ABC-123",
      "namn": "Testdata"
    },
    "transformers": ["response-template"]
  }
}